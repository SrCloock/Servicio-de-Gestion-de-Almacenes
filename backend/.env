# ============================================================
# CONFIGURACIÓN DE ENTORNO — BACKEND
# Copia este archivo a backend/.env y rellena los valores.
# ¡No subas .env a git!
# ============================================================

# ── ENTORNO ──────────────────────────────────────────────────
NODE_ENV=production
# NODE_ENV=development

# ── RED ──────────────────────────────────────────────────────
# IP pública o dominio del servidor donde corre el backend.
# El frontend usará esta IP para conectarse.
PUBLIC_IP=80.24.244.68
PORT=3000
HOST=0.0.0.0

# En desarrollo, origen del frontend Vite (no tocar en producción)
# FRONTEND_DEV_ORIGIN=http://localhost:5173

# ── BASE DE DATOS SAGE200 ─────────────────────────────────────
SAGE200_USER=prueba
SAGE200_PASSWORD=12345
SAGE200_SERVER=localhost
SAGE200_DATABASE=Sage

